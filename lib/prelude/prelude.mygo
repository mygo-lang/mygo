impl Float64: Default[Float64]
  func Default() -> Float64
    0.0
  end
end

impl Bool: Default[Bool]
  func Default() -> Bool
    false
  end
end

impl String: Default[String]
  func Default() -> String
    ""
  end
end

impl[A] OptionADefault[A]: Default[Option[A]]
  func Default() -> Option[A]
    None
  end
end

# ===== Phase 1: From[A, B] / Into[A, B] interfaces and impls =====

interface From[A, B]
  func From(value: A) -> B
end

interface Into[A, B]
  func Into(value: A) -> B
end

# Int -> Int64
impl Int: From[Int, Int64]
  func From(value: Int) -> Int64
    go[Int64] { code: "int64(value)" }
  end
end

# Int64 -> Int
impl Int64: From[Int64, Int]
  func From(value: Int64) -> Int
    go[Int] { code: "int(value)" }
  end
end

# Int64 -> Float64
impl Int64: From[Int64, Float64]
  func From(value: Int64) -> Float64
    go[Float64] { code: "float64(value)" }
  end
end

# Float64 -> Int64
impl Float64: From[Float64, Int64]
  func From(value: Float64) -> Int64
    go[Int64] { code: "int64(value)" }
  end
end

# Float32 -> Float64
impl Float32: From[Float32, Float64]
  func From(value: Float32) -> Float64
    go[Float64] { code: "float64(value)" }
  end
end

# Float64 -> Float32
impl Float64: From[Float64, Float32]
  func From(value: Float64) -> Float32
    go[Float32] { code: "float32(value)" }
  end
end

# Int -> Float64
impl Int: From[Int, Float64]
  func From(value: Int) -> Float64
    go[Float64] { code: "float64(value)" }
  end
end

# Float64 -> Int
impl Float64: From[Float64, Int]
  func From(value: Float64) -> Int
    go[Int] { code: "int(value)" }
  end
end

# Int -> String (via fmt.Sprint)
impl Int: From[Int, String]
  func From(value: Int) -> String
    go[String] { code: "fmt.Sprint(value)" }
  end
end

# String -> Result[Int, String] (via strconv.Atoi)
impl String: From[String, Result[Int, String]]
  func From(value: String) -> Result[Int, String]
    go[Result[Int, String]] {
      code: """
        func() Result[int, string] {
          v, err := strconv.Atoi(value)
          if err != nil {
            return Err[int, string](err.Error())
          }
          return Ok[int, string](v)
        }()
      """
    }
  end
end

# String -> Result[Int64, String] (via strconv.ParseInt)
impl String: From[String, Result[Int64, String]]
  func From(value: String) -> Result[Int64, String]
    go[Result[Int64, String]] {
      code: """
        func() Result[int64, string] {
          v, err := strconv.ParseInt(value, 10, 64)
          if err != nil {
            return Err[int64, string](err.Error())
          }
          return Ok[int64, string](v)
        }()
      """
    }
  end
end

# String -> Result[Float64, String] (via strconv.ParseFloat)
impl String: From[String, Result[Float64, String]]
  func From(value: String) -> Result[Float64, String]
    go[Result[Float64, String]] {
      code: """
        func() Result[float64, string] {
          v, err := strconv.ParseFloat(value, 64)
          if err != nil {
            return Err[float64, string](err.Error())
          }
          return Ok[float64, string](v)
        }()
      """
    }
  end
end

# ===== Phase 1: Option/Result Helper Functions =====

func OptionToResult[A, E](opt: Option[A], errVal: E) -> Result[A, E]
  switch opt
    case Some(v) => Ok(v)
    case None => Err(errVal)
  end
end

func ResultToOption[A, E](res: Result[A, E]) -> Option[A]
  switch res
    case Ok(v) => Some(v)
    case Err(_) => None
  end
end

func ResultFlatten[A, E](res: Result[Result[A, E], E]) -> Result[A, E]
  switch res
    case Ok(inner) => inner
    case Err(e) => Err(e)
  end
end

func OptionFilter[A](opt: Option[A], fn: func(A) -> Bool) -> Option[A]
  switch opt
    case Some(v) then
      if fn(v) => opt else None
    end
    case None => None
  end
end

# ===== Phase 1: Panic / Assert Utilities =====

func Panic(msg: String) -> ()
  go[()] { code: "panic(msg)" }
end

func Assert(cond: Bool, msg: String) -> ()
  go[()] {
    code: """
      if !cond {
        panic(msg)
      }
    """
  }
end
