# Bool
impl Bool: Ord[Bool]
  func Compare(left: Bool, right: Bool) -> Int
    go[Int] {
      code: """
        func() int {
          if left == right { return 0 }
          if !left && right { return -1 }
          return 1
        }()
      """
    }
  end
  func Less(left: Bool, right: Bool) -> Bool
    go[Bool] { code: "!left && right" }
  end
  func Greater(left: Bool, right: Bool) -> Bool
    go[Bool] { code: "left && !right" }
  end
end

