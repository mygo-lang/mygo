package parsec

import testing "go:testing"

# ===== Basic combinators: PPure, PFail =====

func TestPPureReturnsValue(t: Ref[testing.T]) -> ()
  let result = ParseInput(PPure(42), "hello")
  if !result.Ok then
    t.Fatal("PPure should always succeed")
  elsif result.Value != 42 then
    t.Fatalf("PPure(42) = %d, want 42", result.Value)
  else
    ()
  end
  if result.Consumed then
    t.Fatal("PPure should not consume input")
  else
    ()
  end
  if result.State.Index != 0 then
    t.Fatalf("PPure should not advance state, index=%d, want 0", result.State.Index)
  else
    ()
  end
end

func TestPPurePreservesState(t: Ref[testing.T]) -> ()
  let _ = NewState("abc")
  let result = ParseInput(PPure("x"), "abc")
  if result.State.Input != "abc" then
    t.Fatal("PPure should preserve input")
  else
    ()
  end
  if result.State.Position.Line != 1 then
    t.Fatalf("PPure should preserve line, got %d", result.State.Position.Line)
  else
    ()
  end
  if result.State.Position.Column != 1 then
    t.Fatalf("PPure should preserve column, got %d", result.State.Position.Column)
  else
    ()
  end
end

func TestPFailReturnsFailure(t: Ref[testing.T]) -> ()
  let result = ParseInput(PFail[Int]("expected x"), "abc")
  if result.Ok then
    t.Fatal("PFail should always fail")
  end
  if result.Consumed then
    t.Fatal("PFail should not consume input")
  end
  if result.State.Index != 0 then
    t.Fatal("PFail should not advance state")
  end
end

# ===== PMap: map over parsed value =====

func TestPMapTransformsValue(t: Ref[testing.T]) -> ()
  let p = PMap(PChar('x'), func(c: Rune) -> Int
    c as Int
  end)
  let result = ParseInput(p, "xy")
  if !result.Ok then
    t.Fatal("PMap should succeed when inner parser succeeds")
  end
  if result.Value != ('x' as Int) then
    t.Fatalf("PMap(PChar('x'), ...) = %d, want %d", result.Value, ('x' as Int))
  end
end

func TestPMapPropagatesFailure(t: Ref[testing.T]) -> ()
  let p = PMap(PChar('x'), func(c: Rune) -> Int
    c as Int
  end)
  let result = ParseInput(p, "yz")
  if result.Ok then
    t.Fatal("PMap should fail when inner parser fails")
  end
end

# ===== PBind: bind parsed value to next parser =====

func TestPBindChainsParsers(t: Ref[testing.T]) -> ()
  let p = PBind(PChar('a'), func(_: Rune) -> Parser[Rune]
    PChar('b')
  end)
  let result = ParseInput(p, "ab")
  if !result.Ok then
    t.Fatal("PBind should succeed when both parsers succeed")
  end
  if result.Value != 'b' then
    t.Fatalf("PBind result = %d, want %d", result.Value, 'b')
  end
end

# ===== PThen: sequence two parsers, keep second =====

func TestPThenSequencesParsers(t: Ref[testing.T]) -> ()
  let p = PThen(PChar('h'), PThen(PChar('i'), PPure(42)))
  let result = ParseInput(p, "hi!")
  if !result.Ok then
    t.Fatal("PThen should succeed")
  end
  if result.Value != 42 then
    t.Fatalf("PThen result = %d, want 42", result.Value)
  end
  if result.State.Index != 2 then
    t.Fatalf("PThen should consume both inputs, index=%d, want 2", result.State.Index)
  end
end

# ===== POrElse: choice with backtracking =====

func TestPOrElseTakesLeftOnSuccess(t: Ref[testing.T]) -> ()
  let p = POrElse(PChar('a'), PChar('b'))
  let result = ParseInput(p, "ax")
  if !result.Ok then
    t.Fatal("POrElse should succeed when left succeeds")
  end
  if result.Value != 'a' then
    t.Fatalf("POrElse = %d, want %d", result.Value, 'a')
  end
end

func TestPOrElseBacktracksOnFailure(t: Ref[testing.T]) -> ()
  let p = POrElse(PChar('a'), PChar('b'))
  let result = ParseInput(p, "bx")
  if !result.Ok then
    t.Fatal("POrElse should succeed when right succeeds after left fails")
  end
  if result.Value != 'b' then
    t.Fatalf("POrElse = %d, want %d", result.Value, 'b')
  end
end

func TestPOrElseFailsWhenBothFail(t: Ref[testing.T]) -> ()
  let p = POrElse(PChar('a'), PChar('b'))
  let result = ParseInput(p, "cx")
  if result.Ok then
    t.Fatal("POrElse should fail when both alternatives fail")
  end
end

func TestPOrElseDoesNotBacktrackOnConsumedFailure(t: Ref[testing.T]) -> ()
  # Left parser consumes 'a' then fails
  let p = PBind(PChar('a'), func(_: Rune) -> Parser[Rune]
    PFail[Rune]("expected b after a")
  end)
  let choice = POrElse(p, PChar('b'))
  let result = ParseInput(choice, "ax")
  # Should NOT backtrack because left consumed input
  if result.Ok then
    t.Fatal("POrElse should not backtrack on consumed failure")
  end
end

# ===== PChoice: choice among many parsers =====

func TestPChoiceSelectsMatchingParser(t: Ref[testing.T]) -> ()
  let parsers = [
    PChar('a'),
    PChar('b'),
    PChar('c'),
  ]
  let p = PChoice(parsers)
  let result = ParseInput(p, "bx")
  if !result.Ok then
    t.Fatal("PChoice should succeed")
  end
  if result.Value != 'b' then
    t.Fatalf("PChoice = %d, want %d", result.Value, 'b')
  end
end

# ===== PAttempt: force backtracking =====

func TestPAttemptAllowsBacktracking(t: Ref[testing.T]) -> ()
  # Inner parser consumes 'a' then fails; PAttempt resets state and consumption
  let p = POrElse(
    PAttempt(PBind(PChar('a'), func(_: Rune) -> Parser[Rune]
      PFail[Rune]("inner fail")
    end)),
    PChar('a'),
  )
  let result = ParseInput(p, "ax")
  if !result.Ok then
    t.Fatal("PAttempt should allow backtracking so right alternative can retry at the original position")
  end
  if result.Value != 'a' then
    t.Fatalf("PAttempt result = %d, want %d", result.Value, 'a')
  end
end

# ===== PLookAhead: parse without consuming =====

func TestPLookAheadDoesNotConsume(t: Ref[testing.T]) -> ()
  let p = PThen(PLookAhead(PChar('x')), PChar('x'))
  let result = ParseInput(p, "xy")
  if !result.Ok then
    t.Fatal("PLookAhead should succeed")
  end
  if result.Value != 'x' then
    t.Fatalf("PLookAhead result = %d, want %d", result.Value, 'x')
  end
  if result.State.Index != 1 then
    t.Fatalf("PLookAhead should not consume the lookahead, index=%d, want 1", result.State.Index)
  end
end

func TestPLookAheadFailsWhenLookaheadFails(t: Ref[testing.T]) -> ()
  let p = PThen(PLookAhead(PChar('x')), PChar('y'))
  let result = ParseInput(p, "zy")
  if result.Ok then
    t.Fatal("PLookAhead should fail when lookahead doesn't match")
  end
end

# ===== PNotFollowedBy: negative lookahead =====

func TestPNotFollowedBySucceedsWhenNotFollowed(t: Ref[testing.T]) -> ()
  let p = PThen(PNotFollowedBy(PChar('x'), "not x"), PChar('a'))
  let result = ParseInput(p, "ab")
  if !result.Ok then
    t.Fatal("PNotFollowedBy should succeed when x is not next")
  end
  if result.Value != 'a' then
    t.Fatalf("PNotFollowedBy result = %d, want %d", result.Value, 'a')
  end
end

func TestPNotFollowedByFailsWhenFollowed(t: Ref[testing.T]) -> ()
  let p = PNotFollowedBy(PChar('x'), "not x")
  let result = ParseInput(p, "xy")
  if result.Ok then
    t.Fatal("PNotFollowedBy should fail when x IS next")
  end
end

# ===== PMany / PMany1: zero-or-more / one-or-more =====

func TestPManyZeroMatches(t: Ref[testing.T]) -> ()
  let p = PMany(PChar('x'))
  let result = ParseInput(p, "y")
  if !result.Ok then
    t.Fatal("PMany should succeed with empty result")
  end
  if result.Value.Len() != 0 then
    t.Fatalf("PMany empty result length = %d, want 0", result.Value.Len())
  end
end

func TestPManyMatchesMultiple(t: Ref[testing.T]) -> ()
  let p = PMany(PChar('a'))
  let result = ParseInput(p, "aaa")
  if !result.Ok then
    t.Fatal("PMany should succeed")
  end
  if result.Value.Len() != 3 then
    t.Fatalf("PMany length = %d, want 3", result.Value.Len())
  end
  # Check order: PMany returns in reverse order (last consumed first via Prepend)
  let _ = result.Value.Each(func(v: Rune) -> ()
    if v != 'a' then
      t.Fatalf("PMany element = %d, want %d", v, 'a')
    end
  end)
end

func TestPManyStopsOnNonConsumingFailure(t: Ref[testing.T]) -> ()
  let p = PMany(PChar('a'))
  let result = ParseInput(p, "aab")
  if !result.Ok then
    t.Fatal("PMany should succeed")
  end
  if result.Value.Len() != 2 then
    t.Fatalf("PMany length = %d, want 2", result.Value.Len())
  end
  if result.State.Index != 2 then
    t.Fatalf("PMany should stop after consuming 'aa', index=%d, want 2", result.State.Index)
  end
end

func TestPMany1RequiresAtLeastOne(t: Ref[testing.T]) -> ()
  let p = PMany1(PChar('a'))
  let result = ParseInput(p, "x")
  if result.Ok then
    t.Fatal("PMany1 should fail when no input matches")
  end
end

func TestPMany1MatchesOneOrMore(t: Ref[testing.T]) -> ()
  let p = PMany1(PChar('a'))
  let result = ParseInput(p, "aa")
  if !result.Ok then
    t.Fatal("PMany1 should succeed")
  end
  if result.Value.Len() != 2 then
    t.Fatalf("PMany1 length = %d, want 2", result.Value.Len())
  end
end

# ===== POptional: optional parser =====

func TestPOptionalSucceedsWhenPresent(t: Ref[testing.T]) -> ()
  let p = POptional(PChar('a'))
  let result = ParseInput(p, "ab")
  if !result.Ok then
    t.Fatal("POptional should succeed")
  end
  switch result.Value
    case Some(v) then
      if v != 'a' then
        t.Fatalf("POptional Some value = %d, want %d", v, 'a')
      end
    end
    case None then
      t.Fatal("POptional should return Some when parser succeeds")
    end
  end
end

func TestPOptionalReturnsNoneWhenAbsent(t: Ref[testing.T]) -> ()
  let p = POptional(PChar('a'))
  let result = ParseInput(p, "xb")
  if !result.Ok then
    t.Fatal("POptional should succeed with None")
  end
  switch result.Value
    case None => ()
    case Some(_) => t.Fatal("POptional should return None when parser fails without consuming")
  end
end

# ===== PBetween: delimited parsing =====

func TestPBetweenParsesDelimited(t: Ref[testing.T]) -> ()
  let p = PBetween(PChar('('), PDigit(), PChar(')'))
  let result = ParseInput(p, "(5)x")
  if !result.Ok then
    t.Fatal("PBetween should succeed")
  end
  if result.Value != '5' then
    t.Fatalf("PBetween result = %d, want %d", result.Value, '5')
  end
  if result.State.Index != 3 then
    t.Fatalf("PBetween should consume '(5)', index=%d, want 3", result.State.Index)
  end
end

