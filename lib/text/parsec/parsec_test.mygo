# ===== PChar / PString: character and string parsing =====

func TestPCharMatchesExpected(t: Ref[testing.T]) -> ()
  let p = PChar('h')
  let result = ParseInput(p, "hello")
  if !result.Ok then
    t.Fatal("PChar should match 'h'")
  end
  if result.Value != 'h' then
    t.Fatalf("PChar('h') = %d, want %d", result.Value, 'h')
  end
  if result.State.Index != 1 then
    t.Fatalf("PChar should advance by 1, index=%d, want 1", result.State.Index)
  end
end

func TestPCharFailsOnMismatch(t: Ref[testing.T]) -> ()
  let p = PChar('h')
  let result = ParseInput(p, "world")
  if result.Ok then
    t.Fatal("PChar should fail on mismatch")
  end
end

func TestPCharFailsOnEmptyInput(t: Ref[testing.T]) -> ()
  let p = PChar('h')
  let result = ParseInput(p, "")
  if result.Ok then
    t.Fatal("PChar should fail on empty input")
  end
end

func TestPStringMatchesExpected(t: Ref[testing.T]) -> ()
  let p = PString("hello")
  let result = ParseInput(p, "hello world")
  if !result.Ok then
    t.Fatal("PString should match 'hello'")
  end
  if result.Value != "hello" then
    t.Fatalf("PString result = %q, want %q", result.Value, "hello")
  end
  if result.State.Index != 5 then
    t.Fatalf("PString should advance by 5, index=%d, want 5", result.State.Index)
  end
end

func TestPStringFailsOnMismatch(t: Ref[testing.T]) -> ()
  let p = PString("hello")
  let result = ParseInput(p, "world")
  if result.Ok then
    t.Fatal("PString should fail on mismatch")
  end
end

func TestPStringFailsOnPartialMatch(t: Ref[testing.T]) -> ()
  let p = PString("hello")
  let result = ParseInput(p, "hell")
  if result.Ok then
    t.Fatal("PString should fail when input is shorter than expected")
  end
end

# ===== PEof: end of input =====

func TestPEofSucceedsAtEnd(t: Ref[testing.T]) -> ()
  let p = PThen(PString("hello"), PEof())
  let result = ParseInput(p, "hello")
  if !result.Ok then
    t.Fatal("PEof should succeed at end of input")
  end
end

func TestPEofFailsWithRemainingInput(t: Ref[testing.T]) -> ()
  let p = PThen(PString("hello"), PEof())
  let result = ParseInput(p, "hello world")
  if result.Ok then
    t.Fatal("PEof should fail with remaining input")
  end
end

func TestPEofSucceedsOnEmptyInput(t: Ref[testing.T]) -> ()
  let result = ParseInput(PEof(), "")
  if !result.Ok then
    t.Fatal("PEof should succeed on empty input")
  end
end

func TestPEofFailsOnNonEmptyInput(t: Ref[testing.T]) -> ()
  let result = ParseInput(PEof(), "x")
  if result.Ok then
    t.Fatal("PEof should fail on non-empty input")
  end
end

# ===== PDigit / PLetter / PAlphaNum =====

func TestPDigitMatchesDigits(t: Ref[testing.T]) -> ()
  let p = PDigit()
  let result = ParseInput(p, "5abc")
  if !result.Ok then
    t.Fatal("PDigit should match '5'")
  end
  if result.Value != '5' then
    t.Fatalf("PDigit = %d, want %d", result.Value, '5')
  end
end

func TestPDigitFailsOnNonDigit(t: Ref[testing.T]) -> ()
  let p = PDigit()
  let result = ParseInput(p, "abc")
  if result.Ok then
    t.Fatal("PDigit should fail on non-digit")
  end
end

func TestPLetterMatchesLetters(t: Ref[testing.T]) -> ()
  let p = PLetter()
  let result1 = ParseInput(p, "a1")
  if !result1.Ok || result1.Value != 'a' then
    t.Fatal("PLetter should match lowercase")
  end
  let result2 = ParseInput(p, "Z1")
  if !result2.Ok || result2.Value != 'Z' then
    t.Fatal("PLetter should match uppercase")
  end
end

func TestPLetterFailsOnNonLetter(t: Ref[testing.T]) -> ()
  let p = PLetter()
  let result = ParseInput(p, "1abc")
  if result.Ok then
    t.Fatal("PLetter should fail on digit")
  end
end

func TestPAlphaNumMatchesAlphanumeric(t: Ref[testing.T]) -> ()
  let p = PAlphaNum()
  let result1 = ParseInput(p, "a1")
  if !result1.Ok || result1.Value != 'a' then
    t.Fatal("PAlphaNum should match letter")
  end
  let result2 = ParseInput(p, "1abc")
  if !result2.Ok || result2.Value != '1' then
    t.Fatal("PAlphaNum should match digit")
  end
end

func TestPAlphaNumFailsOnNonAlphanumeric(t: Ref[testing.T]) -> ()
  let p = PAlphaNum()
  let result = ParseInput(p, "+abc")
  if result.Ok then
    t.Fatal("PAlphaNum should fail on '+'")
  end
end

# ===== PIdentifier: identifier parsing =====

func TestPIdentifierMatchesSimple(t: Ref[testing.T]) -> ()
  let p = PIdentifier()
  let result = ParseInput(p, "foo123 bar")
  if !result.Ok then
    t.Fatal("PIdentifier should match 'foo123'")
  end
  if result.Value != "foo123" then
    t.Fatalf("PIdentifier = %q, want %q", result.Value, "foo123")
  end
  if result.State.Index != 6 then
    t.Fatalf("PIdentifier should consume 'foo123', index=%d, want 6", result.State.Index)
  end
end

func TestPIdentifierMatchesWithDigits(t: Ref[testing.T]) -> ()
  let p = PIdentifier()
  let result = ParseInput(p, "bar42")
  if !result.Ok then
    t.Fatal("PIdentifier should match 'bar42'")
  end
  if result.Value != "bar42" then
    t.Fatalf("PIdentifier = %q, want %q", result.Value, "bar42")
  end
end

func TestPIdentifierFailsOnDigitStart(t: Ref[testing.T]) -> ()
  let p = PIdentifier()
  let result = ParseInput(p, "1abc")
  if result.Ok then
    t.Fatal("PIdentifier should fail when starting with digit")
  end
end

# ===== PAnyRune: match any single rune =====

func TestPAnyRuneMatchesAnyChar(t: Ref[testing.T]) -> ()
  let p = PAnyRune()
  let result1 = ParseInput(p, "a")
  if !result1.Ok || result1.Value != 'a' then
    t.Fatal("PAnyRune should match 'a'")
  end
  let result2 = ParseInput(p, "1")
  if !result2.Ok || result2.Value != '1' then
    t.Fatal("PAnyRune should match '1'")
  end
  let result3 = ParseInput(p, " ")
  if !result3.Ok || result3.Value != ' ' then
    t.Fatal("PAnyRune should match space")
  end
end

func TestPAnyRuneFailsOnEmpty(t: Ref[testing.T]) -> ()
  let p = PAnyRune()
  let result = ParseInput(p, "")
  if result.Ok then
    t.Fatal("PAnyRune should fail on empty input")
  end
end

# ===== State position tracking =====

func TestStateTracksLineAndColumn(t: Ref[testing.T]) -> ()
  let state = NewState("hello")
  let s1 = AdvanceRune(state)
  if s1.Position.Line != 1 then
    t.Fatalf("After 1 char, line=%d, want 1", s1.Position.Line)
  end
  if s1.Position.Column != 2 then
    t.Fatalf("After 1 char, column=%d, want 2", s1.Position.Column)
  end

  let s2 = AdvanceRune(s1)
  if s2.Position.Column != 3 then
    t.Fatalf("After 2 chars, column=%d, want 3", s2.Position.Column)
  end
end

func TestStateTracksNewline(t: Ref[testing.T]) -> ()
  let state = NewState("ab\ncd")
  let s1 = AdvanceRune(state)
  let s2 = AdvanceRune(s1)
  let s3 = AdvanceRune(s2) # consumes '\n'
  if s3.Position.Line != 2 then
    t.Fatalf("After newline, line=%d, want 2", s3.Position.Line)
  end
  if s3.Position.Column != 1 then
    t.Fatalf("After newline, column=%d, want 1", s3.Position.Column)
  end
end

# ===== Complex parser: parse integers =====

func TestParseInteger(t: Ref[testing.T]) -> ()
  # Build a parser: one or more digits -> parse to Int
  let digitChars = PMany1(PDigit())
  let parseInt = PMap(digitChars, func(rs: Slice[Rune]) -> Int
    go[Int] {
      code: "func() int { n := 0; for _, r := range rs { n = n*10 + int(r-'0') }; return n }()"
      in rs = rs
    }
  end)
  let result = ParseInput(parseInt, "42abc")
  if !result.Ok then
    t.Fatal("parseInt should succeed")
  end
  if result.Value != 42 then
    t.Fatalf("parseInt('42') = %d, want 42", result.Value)
  end
end

# ===== Complex parser: parse simple list of comma-separated words =====

func TestParseCommaSeparatedWords(t: Ref[testing.T]) -> ()
  # word = one or more letters
  let word = PMap(PMany1(PLetter()), func(rs: Slice[Rune]) -> String
    String.FromRunes(rs)
  end)
  # words = word separated by ','
  let words = PSepBy(word, PChar(','))
  let result = ParseInput(words, "hello,world,foo")
  if !result.Ok then
    t.Fatal("parse words should succeed")
  end
  if result.Value.Len() != 3 then
    t.Fatalf("words length = %d, want 3", result.Value.Len())
  end
  let w0 = result.Value.Get(0)
  switch w0
    case Some(v) then
      if v != "hello" then
        t.Fatalf("words[0] = %q, want %q", v, "hello")
      end
    end
    case None => t.Fatal("words[0] should be Some")
  end
  let w1 = result.Value.Get(1)
  switch w1
    case Some(v) then
      if v != "world" then
        t.Fatalf("words[1] = %q, want %q", v, "world")
      end
    end
    case None => t.Fatal("words[1] should be Some")
  end
  let w2 = result.Value.Get(2)
  switch w2
    case Some(v) then
      if v != "foo" then
        t.Fatalf("words[2] = %q, want %q", v, "foo")
      end
    end
    case None => t.Fatal("words[2] should be Some")
  end
end

# ===== Complex parser: parse parenthesized expressions =====

func TestParseParenthesizedExpr(t: Ref[testing.T]) -> ()
  # expr = '(' word ',' word ')'
  let word = PMap(PMany1(PLetter()), func(rs: Slice[Rune]) -> String
    String.FromRunes(rs)
  end)
  let parseTail = func(w1: String) -> Parser[String]
    PBind(PChar(','), func(_: Rune) -> Parser[String]
      PBind(word, func(w2: String) -> Parser[String]
        PPure(w1 + "," + w2)
      end)
    end)
  end
  let p = PBetween(
    PChar('('),
    PBind(word, parseTail),
    PChar(')'),
  )
  let result = ParseInput(p, "(hello,world)x")
  if !result.Ok then
    t.Fatal("parenthesized expr should succeed")
  end
  if result.Value != "hello,world" then
    t.Fatalf("result = %q, want %q", result.Value, "hello,world")
  end
end

# ===== PChoice with many parsers =====

func TestPChoiceWithThreeOptions(t: Ref[testing.T]) -> ()
  let parsers = [
    PString("cat"),
    PString("dog"),
    PString("bird"),
  ]
  let p = PChoice(parsers)
  let result1 = ParseInput(p, "doghouse")
  if !result1.Ok || result1.Value != "dog" then
    t.Fatal("PChoice should match 'dog'")
  end
  let result2 = ParseInput(p, "birdsong")
  if !result2.Ok || result2.Value != "bird" then
    t.Fatal("PChoice should match 'bird'")
  end
end

# ===== PMany with PBind =====

func TestPManyWithPBind(t: Ref[testing.T]) -> ()
  # Parse repeated "ab" sequences
  let p = PBind(PChar('a'), func(_: Rune) -> Parser[Rune]
    PChar('b')
  end)
  let many = PMany(p)
  let result = ParseInput(many, "ababab")
  if !result.Ok then
    t.Fatal("PMany(PBind) should succeed")
  end
  if result.Value.Len() != 3 then
    t.Fatalf("PMany(PBind) length = %d, want 3", result.Value.Len())
  end
end

# ===== POptional with PBetween =====

func TestPOptionalWithBetween(t: Ref[testing.T]) -> ()
  # Parse optional parenthesized group
  let group = POptional(PBetween(PChar('('), PChar('x'), PChar(')')))
  # With parens
  let result1 = ParseInput(group, "(x)y")
  if !result1.Ok then
    t.Fatal("optional group with parens should succeed")
  end
  switch result1.Value
    case Some(v) then
      if v != 'x' then
        t.Fatalf("Some value = %d, want %d", v, 'x')
      end
    end
    case None => t.Fatal("expected Some")
  end
  # Without parens
  let result2 = ParseInput(group, "xy")
  if !result2.Ok then
    t.Fatal("optional group without parens should succeed")
  end
  switch result2.Value
    case None => ()
    case Some(_) => t.Fatal("expected None")
  end
end

# ===== PSepBy1 with PLabel =====

func TestPSepBy1WithLabel(t: Ref[testing.T]) -> ()
  let item = PLabel(PChar('a'), "letter a")
  let sep = PLabel(PChar(','), "comma")
  let p = PSepBy1(item, sep)
  let result = ParseInput(p, "a,a,a")
  if !result.Ok then
    t.Fatal("PSepBy1 with label should succeed")
  end
  if result.Value.Len() != 3 then
    t.Fatalf("PSepBy1 length = %d, want 3", result.Value.Len())
  end
end

# ===== PThen with PPure =====

func TestPThenWithPPure(t: Ref[testing.T]) -> ()
  let p = PThen(PChar('a'), PThen(PChar('b'), PPure("done")))
  let result = ParseInput(p, "ab")
  if !result.Ok then
    t.Fatal("PThen with PPure should succeed")
  end
  if result.Value != "done" then
    t.Fatalf("result = %q, want %q", result.Value, "done")
  end
end

# ===== PChar with multi-byte UTF-8 =====

func TestPCharWithUTF8(t: Ref[testing.T]) -> ()
  let p = PChar('你')
  let result = ParseInput(p, "你好")
  if !result.Ok then
    t.Fatal("PChar should match UTF-8 rune '你'")
  end
  if result.Value != '你' then
    t.Fatalf("PChar('你') = %d, want %d", result.Value, '你')
  end
  # Should advance by 3 bytes (UTF-8 encoding of 你)
  if result.State.Index != 3 then
    t.Fatalf("PChar UTF-8 index=%d, want 3", result.State.Index)
  end
end

# ===== PString with UTF-8 =====

func TestPStringWithUTF8(t: Ref[testing.T]) -> ()
  let p = PString("你好")
  let result = ParseInput(p, "你好世界")
  if !result.Ok then
    t.Fatal("PString should match UTF-8 string '你好'")
  end
  if result.Value != "你好" then
    t.Fatalf("PString result = %q, want %q", result.Value, "你好")
  end
  if result.State.Index != 6 then
    t.Fatalf("PString UTF-8 index=%d, want 6", result.State.Index)
  end
end

# ===== Reply structure validation =====

func TestReplyEmptyError(t: Ref[testing.T]) -> ()
  let pos = Position { Offset: 10, Line: 2, Column: 5 }
  let err = EmptyError(pos)
  if err.Message != "" then
    t.Fatalf("EmptyError message = %q, want empty", err.Message)
  end
  if err.Expected.Len() != 0 then
    t.Fatalf("EmptyError expected length = %d, want 0", err.Expected.Len())
  end
  if err.Position.Offset != 10 then
    t.Fatalf("EmptyError position.Offset = %d, want 10", err.Position.Offset)
  end
end

func TestReplyErrorAt(t: Ref[testing.T]) -> ()
  let pos = Position { Offset: 0, Line: 1, Column: 1 }
  let expected = ["digit", "letter"]
  let err = ErrorAt(pos, "expected digit", expected)
  if err.Message != "expected digit" then
    t.Fatalf("ErrorAt message = %q, want %q", err.Message, "expected digit")
  end
  if err.Expected.Len() != 2 then
    t.Fatalf("ErrorAt expected length = %d, want 2", err.Expected.Len())
  end
end

func TestReplyWithExpected(t: Ref[testing.T]) -> ()
  let pos = Position { Offset: 0, Line: 1, Column: 1 }
  let err = ErrorAt(pos, "expected", ["digit"])
  let err2 = WithExpected(err, "letter")
  if err2.Expected.Len() != 2 then
    t.Fatalf("WithExpected expected length = %d, want 2", err2.Expected.Len())
  end
end
