package psep

struct MyParser[A]
  run: func(MyState) -> MyReply[A]
end

struct MyState
  input: String
  index: Int
end

struct MyReply[A]
  ok: Bool
  consumed: Bool
  value: A
  state: MyState
end

func myPure[A](value: A) -> MyParser[A]
  MyParser[A] {
    run: func(state: MyState) -> MyReply[A]
      MyReply[A] {
        ok: true,
        consumed: false,
        value: value,
        state: state,
      }
    end
  }
end

func myOrElse[A](left: MyParser[A], right: MyParser[A]) -> MyParser[A]
  left
end

func myBind[A, B](p: MyParser[A], f: func(A) -> MyParser[B]) -> MyParser[B]
  p
end

func myThen[A, B](pa: MyParser[A], pb: MyParser[B]) -> MyParser[B]
  pb
end

func myMany[A](p: MyParser[A]) -> MyParser[Slice[A]]
  MyParser[Slice[A]] {
    run: func(state: MyState) -> MyReply[Slice[A]]
      MyReply[Slice[A]] {
        ok: true,
        consumed: false,
        value: [],
        state: state,
      }
    end
  }
end

func mySepBy1[A, S](item: MyParser[A], sep: MyParser[S]) -> MyParser[Slice[A]]
  myBind(item, func(first: A) -> MyParser[Slice[A]]
    myMany(myThen(sep, item))
  end)
end

func mySepBy[A, S](item: MyParser[A], sep: MyParser[S]) -> MyParser[Slice[A]]
  myOrElse(mySepBy1(item, sep), myPure([]))
end
