package main

import fmt "go:fmt"
import strconv "go:strconv"
import strings "go:strings"
import utf8 "go:unicode/utf8"
import ps "lib/text/parsec"

# JsonValue — the parsed representation of any JSON value.

enum JsonValue
  JNull
  JBool(Bool)
  JNumber(Float64)
  JString(String)
  JArray(Slice[JsonValue])
  JObject(Slice[(String, JsonValue)])
end

impl JsonValue
  func ToString(value: JsonValue) -> String
    switch value
      case JNull => "null"
      case JBool(b) => if b => "true" else "false"
      case JNumber(n) => String.FromF64(n)
      case JString(s) => "\"" + jsonEscape(s) + "\""
      case JArray(items) =>
        let parts = items.Map(func(v: JsonValue) -> String
          JsonValue.ToString(v)
        end)
        "[" + strings.Join(parts, ",") + "]"
      case JObject(pairs) =>
        let parts = pairs.Map(func(p: (String, JsonValue)) -> String
          "\"" + jsonEscape(p.0) + "\":" + JsonValue.ToString(p.1)
        end)
        "{" + strings.Join(parts, ",") + "}"
    end
  end
end

func jsonEscape(s: String) -> String
  go[String] {
    code: """
      func() string {
        var b strings.Builder
        for _, r := range s {
          switch r {
          case '"':  b.WriteString("\\\\\\\"")
          case '\\\\': b.WriteString("\\\\\\\\")
          case '\\b': b.WriteString("\\\\b")
          case '\\f': b.WriteString("\\\\f")
          case '\\n': b.WriteString("\\\\n")
          case '\\r': b.WriteString("\\\\r")
          case '\\t': b.WriteString("\\\\t")
          default:
            if r < 0x20 {
              b.WriteString(fmt.Sprintf("\\\\u%04x", r))
            } else {
              b.WriteRune(r)
            }
          }
        }
        return b.String()
      }()
    """
    in s = s
  }
end

# ----- whitespace -----

func ws[A](p: ps.Parser[A]) -> ps.Parser[A]
  let sp = ps.PMany(ps.PSatisfy(func(r: Rune) -> Bool
    r == ' ' || r == '\t' || r == '\n' || r == '\r'
  end, "whitespace"))
  ps.PBetween(sp, p, sp)
end

# ----- null / true / false -----

func pNull() -> ps.Parser[JsonValue]
  ps.PMap(ps.PString("null"), func(_: String) -> JsonValue
    JsonValue.JNull
  end)
end

func pBool() -> ps.Parser[JsonValue]
  ps.POrElse(
    ps.PMap(ps.PString("true"), func(_: String) -> JsonValue
      JsonValue.JBool(true)
    end),
    ps.PMap(ps.PString("false"), func(_: String) -> JsonValue
      JsonValue.JBool(false)
    end),
  )
end

# ----- number -----

func pNumber() -> ps.Parser[JsonValue]
  go[ps.Parser[JsonValue]] {
    code: """
      func() ps.Parser[JsonValue] {
        return ps.Parser[JsonValue]{
          run: func(state ps.State) ps.Reply[JsonValue] {
            if state.index >= len(state.input) {
              return ps.Reply[JsonValue]{ok: false, consumed: false, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "number", ps.EmptyExpected())}
            }
            s := state.input[state.index:]; i := 0
            if i < len(s) && s[i] == '-' { i++ }
            if i >= len(s) || s[i] < '0' || s[i] > '9' {
              return ps.Reply[JsonValue]{ok: false, consumed: false, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "number", ps.EmptyExpected())}
            }
            if s[i] == '0' { i++ } else { for i < len(s) && s[i] >= '0' && s[i] <= '9' { i++ } }
            if i < len(s) && s[i] == '.' {
              i++
              if i >= len(s) || s[i] < '0' || s[i] > '9' {
                return ps.Reply[JsonValue]{ok: false, consumed: false, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "number", ps.EmptyExpected())}
              }
              for i < len(s) && s[i] >= '0' && s[i] <= '9' { i++ }
            }
            if i < len(s) && (s[i] == 'e' || s[i] == 'E') {
              i++
              if i < len(s) && (s[i] == '-' || s[i] == '+') { i++ }
              if i >= len(s) || s[i] < '0' || s[i] > '9' {
                return ps.Reply[JsonValue]{ok: false, consumed: false, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "number", ps.EmptyExpected())}
              }
              for i < len(s) && s[i] >= '0' && s[i] <= '9' { i++ }
            }
            numStr := s[:i]
            f, _ := strconv.ParseFloat(numStr, 64)
            next := state
            next.index += i; next.position.offset += i
            for _, r := range numStr {
              if r == '\n' { next.position.line++; next.position.column = 1 } else { next.position.column++ }
            }
            return ps.Reply[JsonValue]{ok: true, consumed: true, value: JsonValue_JNumber(f), state: next, error: ps.EmptyError(next.position)}
          },
        }
      }()
    """
    in ps = ps
    in strconv = strconv
    in JsonValue = JsonValue
    in JsonValue_JNumber = JsonValue.JNumber
  }
end

# ----- string -----

func pString() -> ps.Parser[JsonValue]
  go[ps.Parser[JsonValue]] {
    code: """
      func() ps.Parser[JsonValue] {
        return ps.Parser[JsonValue]{
          run: func(state ps.State) ps.Reply[JsonValue] {
            if state.index >= len(state.input) || state.input[state.index] != '"' {
              return ps.Reply[JsonValue]{ok: false, consumed: false, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "string", ps.EmptyExpected())}
            }
            s := state.input; pos := state.index + 1
            var buf strings.Builder
            for pos < len(s) {
              ch := s[pos]
              if ch == '"' {
                pos++
                next := state; n := pos - state.index
                next.index = pos; next.position.offset += n; next.position.column += n
                return ps.Reply[JsonValue]{ok: true, consumed: true, value: JsonValue_JString(buf.String()), state: next, error: ps.EmptyError(next.position)}
              }
              if ch == '\\\\' {
                pos++
                if pos >= len(s) {
                  return ps.Reply[JsonValue]{ok: false, consumed: true, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "unterminated string", ps.EmptyExpected())}
                }
                switch s[pos] {
                case '"':  buf.WriteByte('"')
                case '\\\\': buf.WriteByte('\\\\')
                case '/':  buf.WriteByte('/')
                case 'b':  buf.WriteByte('\\b')
                case 'f':  buf.WriteByte('\\f')
                case 'n':  buf.WriteString("\\n")
                case 'r':  buf.WriteByte('\\r')
                case 't':  buf.WriteByte('\\t')
                case 'u':
                  if pos+4 >= len(s) {
                    return ps.Reply[JsonValue]{ok: false, consumed: true, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "invalid unicode escape", ps.EmptyExpected())}
                  }
                  hexStr := s[pos+1:pos+5]
                  r, err := strconv.ParseUint(hexStr, 16, 32)
                  if err != nil {
                    return ps.Reply[JsonValue]{ok: false, consumed: true, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "invalid unicode escape", ps.EmptyExpected())}
                  }
                  var runeBytes [4]byte
                  n := utf8.EncodeRune(runeBytes[:], rune(r))
                  buf.Write(runeBytes[:n])
                  pos += 4
                default:
                  buf.WriteByte('\\\\'); buf.WriteByte(s[pos])
                }
                pos++
              } else {
                buf.WriteByte(ch); pos++
              }
            }
            return ps.Reply[JsonValue]{ok: false, consumed: true, value: JsonValue{}, state: state, error: ps.ErrorAt(state.position, "unterminated string", ps.EmptyExpected())}
          },
        }
      }()
    """
    in ps = ps
    in strings = strings
    in strconv = strconv
    in utf8 = utf8
    in JsonValue = JsonValue
    in JsonValue_JString = JsonValue.JString
  }
end

# ----- JSON value parser (full recursive grammar) -----
#
# The only way to tie the recursive knot in MyGO is to construct
# the full parser graph inside a single `go[]` block since Go supports
# closures that reference variables declared later.

func parseJson(input: String) -> Result[JsonValue, String]
  go[Result[JsonValue, String]] {
    code: """
      func() Result[JsonValue, String] {
        // ---- leaf parsers ----
        nullP := pNull()
        boolP := pBool()
        numP  := pNumber()
        strP  := pString()

        // ---- forward reference for recursive parsers ----
        var valueP ps.Parser[JsonValue]

        // ---- array: "[" ws value (ws "," ws value)* ws "]" ----
        arrBody := ps.PSepBy(ws(valueP), ps.PChar(','))
        arrP := ps.PMap(
          ps.PBetween(ps.PChar('['), arrBody, ps.PChar(']')),
          func(items []JsonValue) JsonValue { return JsonValue_JArray(items) },
        )

        // ---- object: "{" pair ("," pair)* "}" ----
        // pair: string ":" value
        pairP := func(s ps.State) ps.Reply[struct{_0 string; _1 JsonValue}] {
          // Parse key (string)
          kr := pString().run(s)
          if !kr.ok {
            return ps.Reply[struct{_0 string; _1 JsonValue}]{ok: kr.ok, consumed: kr.consumed, state: kr.state, error: kr.error}
          }
          // Extract string value from JString
          keyStr := ""
          if kv, ok := kr.value.(JsonValue_JString); ok {
            keyStr = string(kv)
          }
          // Parse ":"
          cr := ps.PChar(':').run(kr.state)
          if !cr.ok {
            return ps.Reply[struct{_0 string; _1 JsonValue}]{ok: cr.ok, consumed: cr.consumed, state: cr.state, error: cr.error}
          }
          // Parse value
          vr := valueP.run(cr.state)
          if !vr.ok {
            return ps.Reply[struct{_0 string; _1 JsonValue}]{ok: vr.ok, consumed: vr.consumed, state: vr.state, error: vr.error}
          }
          return ps.Reply[struct{_0 string; _1 JsonValue}]{ok: true, consumed: true, value: struct{_0 string; _1 JsonValue}{keyStr, vr.value}, state: vr.state}
        }

        objBody := ps.PSepBy(pairP, ps.PChar(','))
        objP := ps.PMap(
          ps.PBetween(ps.PChar('{'), objBody, ps.PChar('}')),
          func(pairs []struct{_0 string; _1 JsonValue}) JsonValue {
            return JsonValue_JObject(pairs)
          },
        )

        // ---- tie the knot ----
        valueP = ws(ps.PChoice([]ps.Parser[JsonValue]{
          nullP, boolP, numP, strP, arrP, objP,
        }))

        // ---- parse ----
        r := ps.ParseInput(valueP, input)
        if !r.ok {
          errMsg := "parse error at line " + strconv.Itoa(r.error.position.line) + ", column " + strconv.Itoa(r.error.position.column)
          if r.error.message != "" { errMsg += ": " + r.error.message }
          return Result[JsonValue, String]{variant: 1, err: errMsg}
        }
        return Result[JsonValue, String]{variant: 0, ok: r.value}
      }()
    """
    in ps = ps
    in pNull = pNull
    in pBool = pBool
    in pNumber = pNumber
    in pString = pString
    in ws = ws
    in strconv = strconv
    in JsonValue = JsonValue
    in JsonValue_JNull = JsonValue.JNull
    in JsonValue_JBool = JsonValue.JBool
    in JsonValue_JNumber = JsonValue.JNumber
    in JsonValue_JString = JsonValue.JString
    in JsonValue_JArray = JsonValue.JArray
    in JsonValue_JObject = JsonValue.JObject
    in Result = Result
  }
end


func parseJson(input: String) -> Result[JsonValue, String]
  let nullP = pNull()
  let boolP = pBool()
  let numP = pNumber()
  let strP = pString()

  let valueP = ps.Parser[JsonValue] {
    run: func(state: ps.State) -> Parser[JsonValue]
      ws(ps.PChoice([nullP, boolP, numP, strP, arrP, objP]))
    end
  }


  # ---- array: "[" ws value (ws "," ws value)* ws "]" ----
  let arrBody = ps.PSepBy(ws(valueP), ps.PChar(','))
  let arrP = ps.PMap(
    ps.PBetween(ps.PChar('['), arrBody, ps.PChar(']')),
    func(items: Slice[JsonValue]) -> JsonValue
      JsonValue.JArray(items)
    end,
  )


  # ---- object: "{" pair ("," pair)* "}" ----
  # pair: string ":" value
  let pairP = func(s: ps.State) -> ps.Reply[(String, JsonValue)]
    # Parse key (string)
    let kr = pString().run(s)
    if !kr.ok then
      return ps.Reply[(String, JsonValue)] {
        ok: kr.ok,
        consumed: kr.consumed,
        state: kr.state,
        error: kr.error,
        value: ("", JsonValue.JNull)
      }
    end

    # Extract string value from JString
    let keyStr = switch kr.value
      case JsonValue.JString(kv) => kv as String
      case _ = ""
    end
    
    # Parse ":"
    let cr = ps.PChar(':').run(kr.state)
    if !cr.ok then
      return ps.Reply[(String, JsonValue)] {
        ok: cr.ok,
        consumed: cr.consumed,
        state: cr.state,
        error: cr.error,
        value: ("", JsonValue.JNull)
      }
    end
    
    # Parse value
    let vr = valueP.run(cr.state)
    if !vr.ok then
      return ps.Reply[(String, JsonValue)] {
        ok: vr.ok,
        consumed: vr.consumed,
        state: vr.state,
        error: vr.error,
        value: ("", JsonValue.JNull)
      }
    end
    
    ps.Reply[(String, JsonValue)] {
      ok: true,
      consumed: true,
      value: (keyStr, vr.value),
      state: vr.state
    }
  end

  let objBody = ps.PSepBy(pairP, ps.PChar(','))
  let objP = ps.PMap(
    ps.PBetween(ps.PChar('{'), objBody, ps.PChar('}')),
    func(pairs: Slice[(String, JsonValue)]) -> JsonValue
      JsonValue.JObject(pairs)
    end,
  )

  # ---- parse ----
  let r = ps.ParseInput(valueP, input)
  if !r.ok then
    let errMsg = fmt.Sprintf("parse error at line %d, column %d: %s", r.error.position.line, r.error.position.column, r.error.message)
    Err(errMsg)
  else
    Ok(r.value)
  end
end
